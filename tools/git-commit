#!/usr/bin/env bash
set -euo pipefail

#set -x 

# ==============================================================================
# Module Purpose: 自動生成、查閱並編輯 Git Commit 訊息
# Author: Gemini CLI (Senior Systems Engineer)
# License: MIT
# Changelog:
# 2026-03-03: v1.1 - 新增指定路徑、Help 功能、Debug 模式及編輯器整合。
# ==============================================================================

# --- 環境檢查 ---
readonly DEPENDENCIES=("git" "gemini")
for cmd in "${DEPENDENCIES[@]}"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo -e "[ERROR] 缺少必要指令: $cmd" >&2
        exit 1
    fi
done

# --- 常量與全域變數 ---
readonly DEFAULT_TARGET="."
DEBUG_MODE=false
TARGET_PATHS=()
TEMP_COMMIT_FILE=""

# --- 日誌函式 ---
log_info() { echo -e "[\033[0;32mINFO\033[0m] $*"; }
log_debug() { [ "$DEBUG_MODE" = true ] && echo -e "[\033[0;34mDEBUG\033[0m] $*" >&2; }
log_error() { echo -e "[\033[0;31mERROR\033[0m] $*" >&2; }

# --- 使用說明 ---
usage() {
    cat <<EOF
用法: $(basename "$0") [選項] [--] [路徑...]

自動使用 Gemini 分析 Git Diff 並生成專業的 commit 訊息，提供手動編輯功能。

選項:
  -v          開啟偵錯模式 (Debug mode)，顯示詳細執行過程
  -h          顯示此幫助訊息

參數:
  [路徑...]   指定要分析變動的檔案或目錄。支援多個路徑。
              若未提供，預設為當前目錄 (.)。

範例:
  $(basename "$0")                    # 對當前目錄執行
  $(basename "$0") src/               # 只針對 src 目錄進行分析
  $(basename "$0") file1.py file2.py  # 針對多個特定檔案
  $(basename "$0") -v .               # 以偵錯模式對當前目錄執行
EOF
    exit 0
}

# --- 清理機制 ---
cleanup() {
    if [[ -n "${TEMP_COMMIT_FILE:-}" && -f "$TEMP_COMMIT_FILE" ]]; then
        log_debug "正在移除暫存檔: $TEMP_COMMIT_FILE"
        rm -f "$TEMP_COMMIT_FILE"
    fi
}
trap cleanup EXIT SIGINT SIGTERM

# --- 核心邏輯 ---
main() {
    while getopts "vh" opt; do
        case "$opt" in
            v) DEBUG_MODE=true ;;
            h) usage ;;
            *) usage ;;
        esac
    done
    shift $((OPTIND -1))

    # 1. 決定目標路徑
    TARGET_PATHS=("$@")
    [ ${#TARGET_PATHS[@]} -eq 0 ] && TARGET_PATHS=("$DEFAULT_TARGET")    

    # 2. 檢查 Git 變動狀態
    local status_output
    status_output=$(git status --porcelain "${TARGET_PATHS[@]}" 2>/dev/null || true)
    if [ -z "$status_output" ]; then
        log_error "指定路徑下偵測不到任何變動 (Staged 或 Unstaged)。中止操作。"
        exit 1
    fi

    echo -e "\n📄 \033[1m偵測到變動的檔案:\033[0m"
    echo "$status_output"
    echo ""

    # 3. 生成 Commit 訊息
    log_info "正在透過 Gemini 分析變動並生成訊息..."
    
    # 取得 Diff 內容 (包含 HEAD 之後的所有變動)
    local diff_content
    diff_content=$(git diff HEAD "${TARGET_PATHS[@]}" 2>/dev/null || true)
    
    # 如果 staged 但沒有 diff，則取 --cached
    if [ -z "$diff_content" ]; then
        diff_content=$(git diff --cached "${TARGET_PATHS[@]}" 2>/dev/null || true)
    fi

    if [ -z "$diff_content" ]; then
        log_error "無法取得 Diff 內容，請確認檔案是否有實際內容變動。"
        exit 1
    fi

    local generated_msg
    generated_msg=$(echo "$diff_content" | gemini --model gemini-2.5-flash --prompt "你是一位專業的 Staff Engineer。請針對以下 Git Diff 內容，產生一個符合 'Conventional Commits' 規範的繁體中文 Commit Message。只需回傳訊息內容本身，不需引號或額外解釋。" 2>/dev/null || true)

    if [ -z "$generated_msg" ]; then
        log_error "Gemini 生成內容失敗。將改用空白模板。"
        generated_msg="feat: [請輸入 commit 標題]"
    fi

    # 4. 準備編輯界面
    TEMP_COMMIT_FILE=$(mktemp)
    cat <<EOF > "$TEMP_COMMIT_FILE"
$generated_msg

# ------------------------------------------------------------------------------
# [Git Commit 訊息編輯器]
# 指示：
# 1. 在上方編輯您的 Commit 訊息內容。
# 2. 以 '#' 開頭的行將在提交時被自動忽略。
# 3. 若訊息內容為空，將取消本次提交。
#
# 變動檔案清單:
$(echo "$status_output" | sed 's/^/# /')
#
# 詳細變動內容 (Diff):
$(echo "$diff_content" | sed 's/^/# /')
# ------------------------------------------------------------------------------
EOF

    # 5. 調用編輯器
    log_info "開啟編輯器進行查閱與編輯..."
    ${EDITOR:-vi} "$TEMP_COMMIT_FILE"

    # 6. 過濾訊息並檢查
    local final_msg
    final_msg=$(grep -v '^#' "$TEMP_COMMIT_FILE" | sed '/^[[:space:]]*$/d' || true)

    if [ -z "$final_msg" ]; then
        log_error "Commit 訊息為空，操作已取消。"
        exit 1
    fi

    # 7. 執行提交
    log_info "執行 Git Commit..."
    # 先將指定路徑加入索引 (Stage)
    git add "${TARGET_PATHS[@]}"
    
    if git commit -m "$final_msg"; then
        echo -e "\n✅ \033[0;32mCommit 成功！\033[0m"
    else
        log_error "Git Commit 失敗，請檢查 Git 狀態。"
        exit 1
    fi
}

main "$@"
