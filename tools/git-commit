#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# Module Purpose: 自動生成 Commit 訊息並支援自動 Push (v1.9)
# Author: Gemini CLI (Senior Systems Engineer)
# License: MIT
# Changelog:
# 2026-03-03: v1.1 - 初始版本。
# 2026-03-06: v1.9 - 調整流程：先 Add 再分析，支援所有狀態之檔案。
# ==============================================================================

# --- 環境檢查 ---
readonly DEPENDENCIES=("git" "gemini" "grep" "sed")
for cmd in "${DEPENDENCIES[@]}"; do
    command -v "$cmd" >/dev/null 2>&1 || { echo -e "[\033[0;31mERROR\033[0m] 缺少必要指令: $cmd" >&2; exit 1; }
done

# --- 常量與全域變數 ---
readonly DEFAULT_CO_AUTHOR="Gemini CLI <noreply@google.com>"
DEBUG_MODE=false
PUSH_AFTER_COMMIT=false
TARGET_DIR=""
TARGET_PATHS=()
TEMP_COMMIT_FILE=""

# --- 日誌與色彩 ---
log_info()  { echo -e "[\033[0;32mINFO\033[0m] [\033[0;36m$(date +'%H:%M:%S')\033[0m] $*"; }
log_debug() { [ "${DEBUG_MODE:-false}" = true ] && echo -e "[\033[0;34mDEBUG\033[0m] [\033[0;36m$(date +'%H:%M:%S')\033[0m] $*" >&2; }
log_error() { echo -e "[\033[0;31mERROR\033[0m] [\033[0;36m$(date +'%H:%M:%S')\033[0m] $*" >&2; }
bold_text() { echo -en "\033[1m$*\033[0m"; }

# --- 清理機制 ---
cleanup() {
    local exit_code=$?
    [[ -n "${TEMP_COMMIT_FILE:-}" && -f "$TEMP_COMMIT_FILE" ]] && rm -f "$TEMP_COMMIT_FILE"
    exit "$exit_code"
}
trap cleanup EXIT SIGINT SIGTERM

# --- 核心邏輯 ---
main() {
    while getopts "pd:vh" opt; do
        case "$opt" in
            p) PUSH_AFTER_COMMIT=true ;;
            d) TARGET_DIR="$OPTARG" ;;
            v) DEBUG_MODE=true ;;
            *) exit 1 ;;
        esac
    done
    shift $((OPTIND -1))

    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { log_error "非 Git 倉庫。"; exit 1; }

    # 1. 路徑處理
    TARGET_PATHS=("$@")
    [[ -n "$TARGET_DIR" ]] && TARGET_PATHS+=("$TARGET_DIR")
    [[ ${#TARGET_PATHS[@]} -eq 0 ]] && TARGET_PATHS=(".")

    # 2. 先進行 Stage (核心流程變更)
    log_info "執行 Git Stage (add)..."
    git add "${TARGET_PATHS[@]}"

    # 3. 獲取變動狀態
    local status_output
    status_output=$(git status --porcelain "${TARGET_PATHS[@]}" 2>/dev/null || true)
    if [ -z "$status_output" ]; then
        log_error "指定路徑下偵測不到變動。"; exit 1
    fi

    echo -e "\n📄 $(bold_text "已加入 Stage 之變更檔案:")"
    echo "$status_output"

    # 4. 生成 Commit 訊息 (分析 Cached Diff)
    log_info "分析變動並生成訊息中..."
    local diff_content
    diff_content=$(git diff --cached "${TARGET_PATHS[@]}" 2>/dev/null || true)

    if [ -z "$diff_content" ]; then
        # 如果依然無內容變動 (例如僅新增空目錄或空檔案)，改用檔案清單
        log_debug "Cached Diff 為空，改用檔案狀態清單作為參考。"
        diff_content="[檔案狀態清單]\n$status_output"
    fi

    local generated_msg
    generated_msg=$(echo "$diff_content" | gemini --model gemini-2.5-flash --prompt "你是一位專業的 Staff Engineer。請針對以下 Git Diff 內容，產生一個符合 'Conventional Commits' 規範的繁體中文 Commit Message。只需回傳訊息本身。")

    # 5. 準備訊息檔 (含簽名)
    TEMP_COMMIT_FILE=$(mktemp)
    cat <<EOF > "$TEMP_COMMIT_FILE"
${generated_msg:-feat: 更新內容}

Co-Authored-By: $DEFAULT_CO_AUTHOR

# ------------------------------------------------------------------------------
# 變動預覽:
$(echo "$status_output" | sed 's/^/# /')
# ------------------------------------------------------------------------------
EOF

    # 6. 編輯器
    log_info "開啟編輯器 (Editor: ${EDITOR:-vi})..."
    ${EDITOR:-vi} "$TEMP_COMMIT_FILE"

    # 7. Commit
    log_info "執行 Git Commit..."
    if ! grep -v '^#' "$TEMP_COMMIT_FILE" | grep -q '[^[:space:]]'; then
        log_error "訊息為空，已取消。"; exit 1
    fi

    if git commit -F "$TEMP_COMMIT_FILE"; then
        echo -e "\n✅ $(bold_text "\033[0;32mCommit 成功！\033[0m")"
    else
        log_error "Commit 失敗。請手動執行 git status 檢查狀態。"; exit 1
    fi

    # 8. Push
    if [ "$PUSH_AFTER_COMMIT" = true ]; then
        log_info "正在執行 git push..."
        git push && echo -e "🚀 $(bold_text "\033[0;32mPush 成功！\033[0m")" || { log_error "Push 失敗。"; exit 1; }
    fi

    # 9. 報表
    echo -e "\n📦 $(bold_text "本次提交明細:")"
    git diff-tree --no-commit-id --name-only -r HEAD | sed 's/^/  - /'
    echo ""
}

main "$@"
